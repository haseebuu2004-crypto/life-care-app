datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id                   Int       @id @default(autoincrement())
  username             String?   @db.VarChar(255)
  password             String?   @db.VarChar(255)
  raw_password         String?   @db.VarChar(255)
  role                 String?   @default("user") @db.VarChar(50)
  email                String?   @db.VarChar(255)
  googleId             String?   @map("google_id") @db.VarChar(255)
  authProvider         String?   @default("local") @map("auth_provider") @db.VarChar(50)
  ownerId              String?   @map("owner_id") @db.VarChar(255)
  resetToken           String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpiry     DateTime? @map("reset_token_expiry") @db.Timestamp()
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamp()
  updatedAt            DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp()
  sessionToken         String?   @map("session_token") @db.VarChar(255)
  lastActiveAt         DateTime? @map("last_active_at") @db.Timestamp()
  status               String?   @default("active") @db.VarChar(50)
  mustChangePassword   Boolean?  @default(false) @map("must_change_password")
  tokenVersion         Int?      @default(1) @map("token_version")

  @@unique([username, ownerId], name: "username_owner_id")
  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  ownerId   String?   @map("owner_id") @db.VarChar(255)
  name      String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp()

  @@map("categories")
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(255)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp()
  isActive      Int?      @default(1) @map("is_active")
  ownerId       String?   @map("owner_id") @db.VarChar(255)
  sku           String?   @db.VarChar(255)
  categoryId    Int?      @map("category_id")
  unit          String?   @db.VarChar(50)
  sellingPrice  Float?    @map("selling_price") @db.Real
  costPrice     Float?    @map("cost_price") @db.Real
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  variants      ProductVariant[]

  @@unique([name, ownerId], name: "name_owner_id")
  @@map("products")
}

model ProductVariant {
  id        Int       @id @default(autoincrement())
  productId Int?      @map("product_id")
  flavor    String?   @db.VarChar(255)
  vp        Float?    @default(0) @db.Real
  sp        Float?    @default(0) @db.Real
  isActive  Int?      @default(1) @map("is_active")
  ownerId   String?   @map("owner_id") @db.VarChar(255)

  product      Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock        Stock?
  stockEntries StockEntry[]
  saleItems    SaleItem[]

  @@unique([productId, flavor, vp, sp, ownerId], map: "unique_product_variant_attrs")
  @@map("product_variants")
}

// Keeping Stock for migration phase
model Stock {
  id         Int       @id @default(autoincrement())
  variantId  Int?      @unique @map("variant_id")
  qty        Int?      @default(0)
  ownerId    String?   @map("owner_id") @db.VarChar(255)

  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("stock")
}

model StockEntry {
  id             Int       @id @default(autoincrement())
  ownerId        String?   @map("owner_id") @db.VarChar(255)
  variantId      Int?      @map("variant_id")
  quantityAdded  Int?      @map("quantity_added")
  purchasePrice  Float?    @map("purchase_price") @db.Real
  addedBy        String?   @map("added_by") @db.VarChar(255)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp()

  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("stock_entries")
}

model Sale {
  id            Int       @id @default(autoincrement())
  date          DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  customer      String?   @db.VarChar(255)
  totalAmount   Float?    @map("total_amount") @db.Real
  totalProfit   Float?    @map("total_profit") @db.Real
  ownerId       String?   @map("owner_id") @db.VarChar(255)
  
  // new saas fields
  soldBy        String?   @map("sold_by") @db.VarChar(255)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp()

  items         SaleItem[]

  @@map("sales")
}

model SaleItem {
  id           Int       @id @default(autoincrement())
  saleId       Int?      @map("sale_id")
  variantId    Int?      @map("variant_id")
  qty          Int?
  salePrice    Float?    @map("sale_price") @db.Real
  totalAmount  Float?    @map("total_amount") @db.Real
  profit       Float?    @db.Real
  ownerId      String?   @map("owner_id") @db.VarChar(255)

  sale         Sale?     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Attendance {
  id           Int       @id @default(autoincrement())
  name         String?   @db.VarChar(255)
  status       String?   @db.VarChar(50)
  shakeProfit  Float?    @map("shake_profit") @db.Real
  date         DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  ownerId      String?   @map("owner_id") @db.VarChar(255)

  userId       Int?      @map("user_id")
  markedBy     String?   @map("marked_by") @db.VarChar(255)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp()

  @@map("attendance")
}

model Session {
  id          Int       @id @default(autoincrement())
  userId      Int?      @map("user_id")
  tokenHash   String?   @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime? @map("expires_at") @db.Timestamp()
  deviceInfo  String?   @map("device_info") @db.VarChar(255)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp()

  @@map("sessions")
}

model LoginHistory {
  id          Int       @id @default(autoincrement())
  userId      Int?      @map("user_id")
  username    String?   @db.VarChar(255)
  role        String?   @db.VarChar(50)
  device      String?   @db.VarChar(255)
  browser     String?   @db.VarChar(255)
  ipAddress   String?   @map("ip") @db.VarChar(50)
  userAgent   String?   @map("user_agent")
  loginTime   DateTime? @default(now()) @map("login_time") @db.Timestamp()
  logoutTime  DateTime? @map("logout_time") @db.Timestamp()
  
  @@map("login_history")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  token     String?   @unique @db.VarChar(255)
  expiresAt DateTime? @map("expires_at") @db.Timestamp()
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp()

  @@map("refresh_tokens")
}

model BackupLog {
  id               Int       @id @default(autoincrement())
  ownerId          String?   @map("owner_id") @db.VarChar(255)
  backupType       String?   @map("backup_type") @db.VarChar(50)
  fileName         String?   @map("file_name") @db.VarChar(255)
  storageProvider  String?   @map("storage_provider") @db.VarChar(100)
  fileUrl          String?   @map("file_url")
  fileSize         Int?      @map("file_size")
  status           String?   @db.VarChar(50)
  createdBy        String?   @map("created_by") @db.VarChar(100)
  notes            String?
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp()

  @@map("backup_logs")
}
